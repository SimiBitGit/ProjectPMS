# Database Configuration (PostgreSQL - optional)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio_db
DB_USER=portfolio_user
DB_PASSWORD=your_secure_password_here

# API Keys
EODHD_API_KEY=your_eodhd_api_key_here

# Optional API Keys (Fallback)
